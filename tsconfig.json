{
	"compilerOptions": {
		"incremental": true,
		"target": "es2021",
		"lib": ["es2021"],
		"module": "commonjs",
		"allowJs": false,
		"outDir": "./dist",
		"baseUrl": "./src",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"noImplicitAny": true,
		"skipLibCheck": true
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"],
	"ts-node": {
		"swc": true,
		"compilerOptions": {
			"module": "commonjs"
		}
	}
}
