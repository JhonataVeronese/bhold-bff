{
	"name": "bholder-bff",
	"version": "1.0.0",
	"description": "BFF BHold",
	"main": "dist/infra/http/server.js",
	"engines": {
		"node": ">=18",
		"yarn": "1.22.x"
	},
	"author": "BHold",
	"license": "MIT",
	"lint-staged": {
		"*.ts": [
			"eslint --fix"
		]
	},
	"dependencies": {
		"@prisma/client": "^6.0.0",
		"bcrypt": "^5.0.1",
		"cors": "^2.8.5",
		"dotenv": "^16.0.0",
		"express": "^4.17.3",
		"helmet": "^5.0.2",
		"jsonwebtoken": "^9.0.3"
	},
	"scripts": {
		"lint": "eslint src",
		"lint:fix": "eslint src --fix && prettier --write \"src/**/*.ts\"",
		"build": "yarn swc src --out-dir dist --config-file .swcrc && yarn prisma generate --schema prisma/schema.prisma",
		"start": "node dist/infra/http/server.js",
		"dev": "ts-node --transpileOnly ./src/infra/http/server.ts",
		"prepare": "husky install",
		"migrate": "yarn prisma migrate deploy --schema prisma/schema.prisma",
		"prisma:migrate": "yarn prisma migrate deploy --schema prisma/schema.prisma",
		"prisma:migrate:dev": "yarn prisma migrate dev --schema prisma/schema.prisma",
		"prisma:generate": "yarn prisma generate --schema prisma/schema.prisma",
		"prisma:seed": "prisma db seed",
		"docker:db": "docker compose up -d",
		"docker:db:down": "docker compose down",
		"docker:db:logs": "docker compose logs -f db"
	},
	"devDependencies": {
		"@swc/cli": "^0.1.56",
		"@swc/core": "^1.2.161",
		"@types/bcrypt": "^5.0.0",
		"@types/cors": "^2.8.13",
		"@types/express": "^4.17.13",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^22.15.0",
		"@typescript-eslint/eslint-plugin": "^5.17.0",
		"@typescript-eslint/parser": "^5.17.0",
		"eslint": "^7.12.1",
		"eslint-config-prettier": "^8.5.0",
		"eslint-config-standard": "^16.0.3",
		"eslint-plugin-import": "^2.22.1",
		"eslint-plugin-node": "^11.1.0",
		"eslint-plugin-prettier": "^4.0.0",
		"eslint-plugin-promise": "^4.2.1",
		"eslint-plugin-unused-imports": "^2.0.0",
		"husky": "^7.0.4",
		"lint-staged": "^12.3.7",
		"prettier": "^2.6.2",
		"prisma": "^6.0.0",
		"ts-node": "^10.7.0",
		"typescript": "^4.6.3"
	}
}
