generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UsuarioPerfil {
  /// Plataforma (cadastro de tenants/usuários; testes). Vinculado ao tenant "system" no seed.
  SUPER
  ADMIN
  OPERADOR
  LEITURA
}

enum TipoContaBancaria {
  CORRENTE
  POUPANCA
  PAGAMENTO
}

enum FinanceType {
  PAYABLE
  RECEIVABLE
}

enum RecurrenceType {
  UNICA
  MENSAL
  ANUAL
  @@map("RecurrenceType")
}

enum FormaPagamentoTipo {
  DINHEIRO
  PIX
  TRANSFERENCIA
  CARTAO_CREDITO
  CARTAO_DEBITO
  OUTROS
}

enum MovimentoContaTipo {
  ABERTURA
  AJUSTE
}

enum PlanoContaNatureza {
  DEBITO
  CREDITO
}

/// Empresa / organização (isolamento multi-tenant).
model Tenant {
  id           Int      @id @default(autoincrement())
  /// Razão social / nome legal.
  nome         String
  /// Identificador único (ex.: subdomínio), minúsculo.
  slug         String   @unique
  nomeFantasia String
  /// CNPJ normalizado (14 dígitos), único quando informado.
  cnpj         String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  fornecedores            Fornecedor[]
  /// Contas bancárias da própria empresa (fluxo de caixa, pagar/receber).
  contasBancariasEmpresa ContaBancariaEmpresa[]
  /// Contas de clientes/fornecedores (destino TED/PIX, cadastro de terceiros).
  contasBancariasTerceiro ContaBancariaTerceiro[]
  usuarios                Usuario[]
  clientes                Cliente[]
  formasPagamento         FormaPagamento[]
  lancamentosFinanceiros  LancamentoFinanceiro[]
  movimentosContaEmpresa  MovimentoContaEmpresa[]
  gruposPlanoContas       GrupoPlanoConta[]
  planosContas            PlanoConta[]
}

model Fornecedor {
  id                     Int                    @id @default(autoincrement())
  tenantId               Int
  tenant                 Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cnpj                   String
  razaoSocial            String
  nomeFantasia           String
  municipio              String
  uf                     String                 @db.VarChar(2)
  payload                Json?
  createdAt              DateTime               @default(now())
  contasBancariasTerceiro ContaBancariaTerceiro[]
  lancamentosFinanceiros LancamentoFinanceiro[]

  @@unique([tenantId, cnpj])
  @@index([tenantId])
}

model Cliente {
  id                     Int                    @id @default(autoincrement())
  tenantId               Int
  tenant                 Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cnpj                   String
  razaoSocial            String
  nomeFantasia           String
  municipio              String
  uf                     String                 @db.VarChar(2)
  payload                Json?
  createdAt              DateTime               @default(now())
  contasBancariasTerceiro ContaBancariaTerceiro[]
  lancamentosFinanceiros LancamentoFinanceiro[]

  @@unique([tenantId, cnpj])
  @@index([tenantId])
}

/// Conta bancária da própria empresa (tenant). Usada em lançamentos (caixa).
model ContaBancariaEmpresa {
  id                     Int                    @id @default(autoincrement())
  tenantId               Int
  tenant                 Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  nome                   String
  bankIspb               String
  bankCode               Int?
  bankFullName           String
  agencia                String
  agenciaDigito          String?
  conta                  String
  contaDigito            String?
  tipoConta              TipoContaBancaria
  pixChave               String                 @default("")
  dataSaldoInicial       DateTime?              @db.Date
  saldoInicial           Decimal?               @db.Decimal(18, 2)
  createdAt              DateTime               @default(now())
  lancamentosFinanceirosOrigem  LancamentoFinanceiro[] @relation("LancamentoContaOrigem")
  lancamentosFinanceirosDestino LancamentoFinanceiro[] @relation("LancamentoContaDestino")
  formasPagamentoPadrao  FormaPagamento[]
  movimentos             MovimentoContaEmpresa[]

  @@index([tenantId])
  @@index([tenantId, nome])
}

/// Conta bancária de terceiro (cliente ou fornecedor): dados para pagamento/recebimento, não é o caixa da empresa.
model ContaBancariaTerceiro {
  id            Int         @id @default(autoincrement())
  tenantId      Int
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fornecedorId  Int?
  fornecedor    Fornecedor? @relation(fields: [fornecedorId], references: [id], onDelete: Cascade)
  clienteId     Int?
  cliente       Cliente?    @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  bankIspb      String
  bankCode      Int?
  bankFullName  String
  agencia       String
  agenciaDigito String?
  conta         String
  contaDigito   String?
  tipoConta     TipoContaBancaria
  pixChave      String      @default("")
  createdAt     DateTime    @default(now())
  lancamentosFinanceiros LancamentoFinanceiro[]

  @@index([tenantId])
  @@index([tenantId, fornecedorId])
  @@index([tenantId, clienteId])
}

model LancamentoFinanceiro {
  id                      Int                  @id @default(autoincrement())
  tenantId                Int
  tenant                  Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type                    FinanceType
  valor                   Decimal              @db.Decimal(18, 2)
  dataCompetencia         DateTime             @db.Date
  dataVencimento          DateTime             @db.Date
  dataPagamento           DateTime?            @db.Date
  /// Conta da própria empresa onde o caixa se movimenta.
  contaBancariaEmpresaId  Int
  contaBancariaEmpresa    ContaBancariaEmpresa @relation("LancamentoContaOrigem", fields: [contaBancariaEmpresaId], references: [id], onDelete: Restrict)
  /// Opcional: conta bancária do terceiro (destino em pagamentos / referência em recebimentos).
  contaBancariaTerceiroId Int?
  contaBancariaTerceiro   ContaBancariaTerceiro? @relation(fields: [contaBancariaTerceiroId], references: [id], onDelete: SetNull)
  contaBancariaDestinoId  Int?
  contaBancariaDestino    ContaBancariaEmpresa? @relation("LancamentoContaDestino", fields: [contaBancariaDestinoId], references: [id], onDelete: SetNull)
  formaPagamentoId        Int?
  formaPagamento          FormaPagamento?      @relation(fields: [formaPagamentoId], references: [id], onDelete: Restrict)
  planoContaId            Int?
  planoConta              PlanoConta?          @relation(fields: [planoContaId], references: [id], onDelete: SetNull)
  fornecedorId            Int?
  fornecedor              Fornecedor?          @relation(fields: [fornecedorId], references: [id], onDelete: Restrict)
  clienteId               Int?
  cliente                 Cliente?             @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  numeroDocumento         String               @default("")
  contaGerencial          String               @default("")
  pixChave                String               @default("")
  descricao               String               @default("")
  recorrenciaAtiva        Boolean              @default(false)
  recorrenciaTipo         RecurrenceType
  recorrenciaQuantidade   Int                  @default(1)
  /// Mesmo UUID em todos os lançamentos gerados numa mesma série (recorrência expandida).
  recorrenciaGrupoId      String?              @db.Uuid
  /// Parcela 1..N dentro do grupo (null quando lançamento avulso).
  recorrenciaParcela      Int?
  observacao              String               @default("")
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  @@index([tenantId])
  @@index([tenantId, type])
  @@index([dataCompetencia])
  @@index([contaBancariaTerceiroId])
  @@index([contaBancariaDestinoId])
  @@index([formaPagamentoId])
  @@index([planoContaId])
  @@index([recorrenciaGrupoId])
}

model FormaPagamento {
  id             Int                @id @default(autoincrement())
  tenantId       Int
  tenant         Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  nome           String
  tipo           FormaPagamentoTipo
  contaBancariaEmpresaId Int?
  contaBancariaEmpresa   ContaBancariaEmpresa? @relation(fields: [contaBancariaEmpresaId], references: [id], onDelete: SetNull)
  prazoDias      Int?
  taxaPercentual Decimal?           @db.Decimal(5, 2)
  ativo          Boolean            @default(true)
  padrao         Boolean            @default(false)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  lancamentos    LancamentoFinanceiro[]

  @@unique([tenantId, nome])
  @@index([tenantId])
  @@index([tenantId, tipo])
}

model MovimentoContaEmpresa {
  id                   Int                 @id @default(autoincrement())
  tenantId             Int
  tenant               Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contaBancariaEmpresaId Int
  contaBancariaEmpresa ContaBancariaEmpresa @relation(fields: [contaBancariaEmpresaId], references: [id], onDelete: Cascade)
  tipo                 MovimentoContaTipo
  valor                Decimal             @db.Decimal(18, 2)
  dataMovimento        DateTime            @db.Date
  descricao            String              @default("")
  observacao           String              @default("")
  createdAt            DateTime            @default(now())

  @@index([tenantId])
  @@index([contaBancariaEmpresaId])
  @@index([dataMovimento])
}

model GrupoPlanoConta {
  id          Int                @id @default(autoincrement())
  tenantId    Int
  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  codigo      String
  descricao   String
  nivel       Int
  parentId    Int?
  parent      GrupoPlanoConta?   @relation("GrupoPlanoContaHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    GrupoPlanoConta[]  @relation("GrupoPlanoContaHierarchy")
  contas      PlanoConta[]
  systemDefault Boolean            @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@unique([tenantId, codigo])
  @@index([tenantId])
  @@index([parentId])
  @@index([tenantId, nivel])
}

model PlanoConta {
  id         Int                @id @default(autoincrement())
  tenantId   Int
  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  descricao  String
  natureza   PlanoContaNatureza
  grupoId    Int
  grupo      GrupoPlanoConta    @relation(fields: [grupoId], references: [id], onDelete: Restrict)
  lancamentos LancamentoFinanceiro[]
  ativo      Boolean            @default(true)
  systemDefault Boolean         @default(false)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([tenantId])
  @@index([grupoId])
  @@index([tenantId, natureza])
}

model Usuario {
  id        Int            @id @default(autoincrement())
  tenantId  Int
  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  nome      String
  email     String
  senhaHash String
  perfil    UsuarioPerfil
  ativo     Boolean        @default(true)
  createdAt DateTime       @default(now())

  @@unique([tenantId, email])
  @@index([tenantId])
}
