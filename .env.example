ENVIRONMENT=HML
PORT=3333
TZ=
# Banco local (Docker): copie este arquivo para .env e rode `yarn docker:db` antes das migrations.
# URL alinhada ao docker-compose.yml (Postgres na porta 5433).
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/bhold_api?schema=public"

# Opcional: limite de linhas em GET /public/tenants (padrão 200, máx. 500)
PUBLIC_TENANTS_MAX=

# Token compartilhado API ↔ front (obrigatório em produção). Todas as requisições devem enviar:
#   X-BHOLD-API-Token: <mesmo valor>
# Isso vale também para GET /public/tenants e POST /auth/login — não exige JWT (usuário ainda não logado).
# Gere um valor forte: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BHOLD_API_TOKEN=

# JWT (obrigatório em produção): mínimo 16 caracteres. Ex.: openssl rand -base64 32
JWT_SECRET=
# Opcional. Ex.: 8h, 7d, 3600 (segundos)
JWT_EXPIRES_IN=8h

# Rotas protegidas por JWT (além do X-BHOLD-API-Token):
# Authorization: Bearer <JWT do POST /auth/login>
# X-Tenant-Id: <id numérico do tenant> (SUPER pode usar qualquer tenant existente)
#
# /auth/login e /public/tenants — exigem X-BHOLD-API-Token; login não exige JWT.
# Super usuário (seed): email super@bhold.local, senha Super123! (sem tenantId no body)
# Demais logins: informe tenantId no JSON junto com email e senha.
#
# /tenants e /usuarios — JWT perfil SUPER.
#
# Financeiro (JWT + X-Tenant-Id):
#   GET/POST /clientes — clientes (contrapartida em contas a receber)
#   GET/POST /contas-a-pagar | /contas-a-receber | /lancamentos-financeiros (?kind=payable|receivable)
